{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
    "UUID": "com.vox.intercom",
    "Name": "Vox",
    "Version": "1.0.0.0",
    "Author": "Vox",
    "Description": "Control your Vox intercom — push-to-talk, mode switching, team/user selection — right from your Stream Deck.",
    "Icon": "imgs/plugin-icon",
    "Category": "Vox",
    "CategoryIcon": "imgs/category-icon",
    "CodePath": "bin/plugin.js",
    "SDKVersion": 2,
    "Software": {
        "MinimumVersion": "6.6"
    },
    "Nodejs": {
        "Version": "20",
        "Debug": "enabled"
    },
    "OS": [
        { "Platform": "mac", "MinimumVersion": "13" },
        { "Platform": "windows", "MinimumVersion": "10" }
    ],
    "Actions": [
        {
            "UUID": "com.vox.intercom.talk",
            "Name": "Push to Talk",
            "Icon": "imgs/actions/talk",
            "Tooltip": "Hold to talk on Vox",
            "States": [
                { "Image": "imgs/actions/talk", "TitleAlignment": "bottom" }
            ]
        },
        {
            "UUID": "com.vox.intercom.mode",
            "Name": "Status Mode",
            "Icon": "imgs/actions/mode",
            "Tooltip": "Cycle availability: Available → Busy → DND",
            "States": [
                { "Image": "imgs/actions/mode", "TitleAlignment": "bottom" }
            ]
        },
        {
            "UUID": "com.vox.intercom.team",
            "Name": "Switch Team",
            "Icon": "imgs/actions/team",
            "Tooltip": "Cycle through your teams",
            "States": [
                { "Image": "imgs/actions/team", "TitleAlignment": "bottom" }
            ]
        },
        {
            "UUID": "com.vox.intercom.user",
            "Name": "Select User",
            "Icon": "imgs/actions/user",
            "Tooltip": "Cycle through online users",
            "States": [
                { "Image": "imgs/actions/user", "TitleAlignment": "bottom" }
            ]
        },
        {
            "UUID": "com.vox.intercom.logo",
            "Name": "Vox Logo / Directory",
            "Icon": "imgs/actions/logo",
            "Tooltip": "Shows Vox logo, preview names while browsing, and message alerts",
            "States": [
                { "Image": "imgs/actions/logo", "TitleAlignment": "bottom" }
            ]
        },
        {
            "UUID": "com.vox.intercom.panel",
            "Name": "Show Panel",
            "Icon": "imgs/actions/panel",
            "Tooltip": "Show the Vox panel window",
            "States": [
                { "Image": "imgs/actions/panel", "TitleAlignment": "bottom" }
            ]
        }
    ]
}
